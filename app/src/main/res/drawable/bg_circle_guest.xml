<?xml version="1.0" encoding="utf-8"?>
<!--
    ╔═══════════════════════════════════════════════════╗
    ║  Кружок «ГОСТЬ»  —  Green Orbital Glass          ║
    ╠═══════════════════════════════════════════════════╣
    ║  Fill  : radial #00E676  center 40% → edge 10%   ║
    ║  Border: rgba(255,255,255, 0.10)                  ║
    ╚═══════════════════════════════════════════════════╝
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Внешнее зелёное свечение (glow ~30%) -->
    <item>
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="50%p"
                android:centerX="0.5"
                android:centerY="0.5"
                android:startColor="#4D00E676"
                android:endColor="#0000E676" />
        </shape>
    </item>

    <!-- Основной fill: radial center 40% → edge 10% -->
    <item
        android:bottom="8dp"
        android:left="8dp"
        android:right="8dp"
        android:top="8dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="50%p"
                android:centerX="0.5"
                android:centerY="0.5"
                android:startColor="#6600E676"
                android:endColor="#1A00E676" />
            <stroke
                android:width="1dp"
                android:color="#1AFFFFFF" />
        </shape>
    </item>

    <!-- Внутренний блик (inset highlight) -->
    <item
        android:bottom="52dp"
        android:left="20dp"
        android:right="20dp"
        android:top="12dp">
        <shape android:shape="oval">
            <gradient
                android:type="linear"
                android:angle="270"
                android:startColor="#33FFFFFF"
                android:endColor="#00FFFFFF" />
        </shape>
    </item>

</layer-list>