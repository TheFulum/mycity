<?xml version="1.0" encoding="utf-8"?>
<!-- Настраивается через tag или data binding; цвет и иконку выставляем программно -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Круг-фон -->
    <View
        android:id="@+id/circleBackground"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_circle"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintDimensionRatio="1:1"/>

    <!-- Иконка -->
    <ImageView
        android:id="@+id/circleIcon"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginBottom="4dp"
        app:layout_constraintTop_toTopOf="@id/circleBackground"
        app:layout_constraintBottom_toTopOf="@id/circleLabel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_chainStyle="packed"/>

    <!-- Подпись -->
    <TextView
        android:id="@+id/circleLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/text_primary"
        android:textSize="10sp"
        android:letterSpacing="0.1"
        app:layout_constraintTop_toBottomOf="@id/circleIcon"
        app:layout_constraintBottom_toBottomOf="@id/circleBackground"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>